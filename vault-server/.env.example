# Database (same PostgreSQL instance as main app)
DATABASE_URL=postgresql://user:password@localhost:9999/askworx

# JWT — must match the secret used by the main app's auth module
JWT_SECRET=your-super-secret-jwt-key

# Server
PORT=4001
NODE_ENV=development

# Cloudinary (sign up at cloudinary.com — free tier works)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# File limits
MAX_DOC_SIZE_MB=20
MAX_VIDEO_SIZE_MB=500

# FFmpeg temp directory (absolute path)
FFMPEG_TEMP_DIR=/tmp/vault-ffmpeg
